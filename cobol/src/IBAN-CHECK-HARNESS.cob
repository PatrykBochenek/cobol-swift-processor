IDENTIFICATION DIVISION.
PROGRAM-ID. IBAN-CHECK-HARNESS.

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT TEST-CASE-FILE ASSIGN TO "data/reference/iban-test-cases.dat"
        ORGANIZATION IS LINE SEQUENTIAL.

DATA DIVISION.
FILE SECTION.
FD TEST-CASE-FILE.
01 TEST-CASE-LINE                 PIC X(128).

WORKING-STORAGE SECTION.
01 WS-END-OF-FILE                 PIC X VALUE "N".
01 WS-EXPECTED                     PIC X.
01 WS-IBAN                         PIC X(64).
01 WS-EXPECTED-REASON              PIC X(40).
01 WS-DESCRIPTION                  PIC X(60).
01 WS-ACTUAL                       PIC X.
01 WS-ERROR-MESSAGE                PIC X(80).
01 WS-TOTAL                        PIC 9(4) VALUE 0.
01 WS-PASSED                       PIC 9(4) VALUE 0.
01 WS-FAILED                       PIC 9(4) VALUE 0.

PROCEDURE DIVISION.
MAIN-LOGIC.
    OPEN INPUT TEST-CASE-FILE
    PERFORM UNTIL WS-END-OF-FILE = "Y"
        READ TEST-CASE-FILE
            AT END
                MOVE "Y" TO WS-END-OF-FILE
            NOT AT END
                PERFORM PROCESS-TEST-LINE
        END-READ
    END-PERFORM
    CLOSE TEST-CASE-FILE

    DISPLAY "----------------------------------------"
    DISPLAY "IBAN test summary"
    DISPLAY "Total:  " WS-TOTAL
    DISPLAY "Passed: " WS-PASSED
    DISPLAY "Failed: " WS-FAILED

    IF WS-FAILED > 0
        MOVE 1 TO RETURN-CODE
    END-IF
    GOBACK.

PROCESS-TEST-LINE.
    IF TEST-CASE-LINE = SPACES OR TEST-CASE-LINE(1:1) = "#"
        EXIT PARAGRAPH
    END-IF

    MOVE SPACES TO WS-EXPECTED WS-IBAN WS-EXPECTED-REASON WS-DESCRIPTION
    MOVE SPACES TO WS-ACTUAL WS-ERROR-MESSAGE
    UNSTRING TEST-CASE-LINE DELIMITED BY "|"
        INTO WS-EXPECTED WS-IBAN WS-EXPECTED-REASON WS-DESCRIPTION
    END-UNSTRING

    IF WS-EXPECTED NOT = "Y" AND WS-EXPECTED NOT = "N"
        EXIT PARAGRAPH
    END-IF

    ADD 1 TO WS-TOTAL
    CALL "IBAN-CHECK" USING WS-IBAN WS-ACTUAL WS-ERROR-MESSAGE

    IF WS-EXPECTED = WS-ACTUAL AND WS-EXPECTED-REASON = WS-ERROR-MESSAGE(1:40)
        ADD 1 TO WS-PASSED
        DISPLAY "PASS | " WS-DESCRIPTION
    ELSE
        ADD 1 TO WS-FAILED
        DISPLAY "FAIL | " WS-DESCRIPTION
        DISPLAY "  expected flag: " WS-EXPECTED " actual: " WS-ACTUAL
        DISPLAY "  iban: " WS-IBAN
        DISPLAY "  expected reason: " WS-EXPECTED-REASON
        DISPLAY "  actual reason:   " WS-ERROR-MESSAGE
    END-IF.
