IDENTIFICATION DIVISION.
PROGRAM-ID. IBAN-CHECK.

DATA DIVISION.
WORKING-STORAGE SECTION.
01 WS-CLEAN-IBAN                 PIC X(34) VALUE SPACES.
01 WS-CLEAN-LEN                  PIC 99 VALUE 0.
01 WS-COUNTRY-CODE               PIC XX VALUE SPACES.
01 WS-REARRANGED-IBAN            PIC X(34) VALUE SPACES.
01 WS-HEAD-LEN                   PIC 99 VALUE 0.
01 WS-TAIL-START                 PIC 99 VALUE 0.
01 WS-INDEX                      PIC 99 VALUE 0.
01 WS-COUNTRY-INDEX              PIC 99 VALUE 0.
01 WS-COUNTRY-FOUND              PIC X VALUE "N".
01 WS-EXPECTED-LEN               PIC 99 VALUE 0.
01 WS-CURRENT-CHAR               PIC X VALUE SPACE.
01 WS-DIGIT                      PIC 9 VALUE 0.
01 WS-REMAINDER                  PIC 9(4) VALUE 0.
01 WS-ORD-A                      PIC 9(4) VALUE 0.
01 WS-ORD-CURRENT                PIC 9(4) VALUE 0.
01 WS-LETTER-VALUE               PIC 99 VALUE 0.
01 WS-TENS                       PIC 9 VALUE 0.
01 WS-ONES                       PIC 9 VALUE 0.
01 WS-MAX-LEN                    PIC 99 VALUE 34.
01 WS-SUPPORTED-COUNTRIES.
    05 WS-COUNTRY-ENTRY OCCURS 9 TIMES.
        10 WS-COUNTRY-CODE-REF   PIC XX.
        10 WS-COUNTRY-LEN-REF    PIC 99.

LINKAGE SECTION.
01 LK-IBAN-IN                    PIC X(64).
01 LK-VALID-FLAG                 PIC X.
01 LK-ERROR-MSG                  PIC X(80).

PROCEDURE DIVISION USING LK-IBAN-IN LK-VALID-FLAG LK-ERROR-MSG.
MAIN-LOGIC.
    MOVE "N" TO LK-VALID-FLAG
    MOVE SPACES TO LK-ERROR-MSG
    MOVE SPACES TO WS-CLEAN-IBAN
    MOVE 0 TO WS-CLEAN-LEN

    PERFORM NORMALIZE-IBAN

    IF WS-CLEAN-LEN = 0
        MOVE "IBAN is empty" TO LK-ERROR-MSG
        GOBACK
    END-IF

    IF WS-CLEAN-LEN < 15 OR WS-CLEAN-LEN > WS-MAX-LEN
        MOVE "IBAN length out of range" TO LK-ERROR-MSG
        GOBACK
    END-IF

    IF WS-CLEAN-IBAN(1:1) IS NOT ALPHABETIC OR WS-CLEAN-IBAN(2:1) IS NOT ALPHABETIC
        MOVE "Country code must be letters" TO LK-ERROR-MSG
        GOBACK
    END-IF

    IF WS-CLEAN-IBAN(3:1) IS NOT NUMERIC OR WS-CLEAN-IBAN(4:1) IS NOT NUMERIC
        MOVE "Check digits must be numeric" TO LK-ERROR-MSG
        GOBACK
    END-IF

    MOVE WS-CLEAN-IBAN(1:2) TO WS-COUNTRY-CODE
    PERFORM VALIDATE-COUNTRY-RULES
    IF LK-ERROR-MSG NOT = SPACES
        GOBACK
    END-IF

    PERFORM VARYING WS-INDEX FROM 1 BY 1 UNTIL WS-INDEX > WS-CLEAN-LEN
        MOVE WS-CLEAN-IBAN(WS-INDEX:1) TO WS-CURRENT-CHAR
        IF WS-CURRENT-CHAR IS NOT ALPHABETIC AND WS-CURRENT-CHAR IS NOT NUMERIC
            MOVE "IBAN contains invalid characters" TO LK-ERROR-MSG
            GOBACK
        END-IF
    END-PERFORM

    PERFORM BUILD-REARRANGED-IBAN
    PERFORM CALCULATE-MOD97

    IF WS-REMAINDER NOT = 1
        MOVE "IBAN checksum failed" TO LK-ERROR-MSG
        GOBACK
    END-IF

    MOVE "Y" TO LK-VALID-FLAG
    MOVE "OK" TO LK-ERROR-MSG
    GOBACK.

INITIALIZE-COUNTRY-TABLE.
    MOVE "GB" TO WS-COUNTRY-CODE-REF(1)
    MOVE 22 TO WS-COUNTRY-LEN-REF(1)
    MOVE "DE" TO WS-COUNTRY-CODE-REF(2)
    MOVE 22 TO WS-COUNTRY-LEN-REF(2)
    MOVE "FR" TO WS-COUNTRY-CODE-REF(3)
    MOVE 27 TO WS-COUNTRY-LEN-REF(3)
    MOVE "ES" TO WS-COUNTRY-CODE-REF(4)
    MOVE 24 TO WS-COUNTRY-LEN-REF(4)
    MOVE "NL" TO WS-COUNTRY-CODE-REF(5)
    MOVE 18 TO WS-COUNTRY-LEN-REF(5)
    MOVE "NO" TO WS-COUNTRY-CODE-REF(6)
    MOVE 15 TO WS-COUNTRY-LEN-REF(6)
    MOVE "DK" TO WS-COUNTRY-CODE-REF(7)
    MOVE 18 TO WS-COUNTRY-LEN-REF(7)
    MOVE "FI" TO WS-COUNTRY-CODE-REF(8)
    MOVE 18 TO WS-COUNTRY-LEN-REF(8)
    MOVE "GR" TO WS-COUNTRY-CODE-REF(9)
    MOVE 27 TO WS-COUNTRY-LEN-REF(9).

NORMALIZE-IBAN.
    PERFORM VARYING WS-INDEX FROM 1 BY 1 UNTIL WS-INDEX > LENGTH OF LK-IBAN-IN
        MOVE LK-IBAN-IN(WS-INDEX:1) TO WS-CURRENT-CHAR
        IF WS-CURRENT-CHAR NOT = SPACE
            ADD 1 TO WS-CLEAN-LEN
            IF WS-CLEAN-LEN > WS-MAX-LEN
                MOVE "IBAN length out of range" TO LK-ERROR-MSG
                GOBACK
            END-IF
            MOVE FUNCTION UPPER-CASE(WS-CURRENT-CHAR) TO WS-CLEAN-IBAN(WS-CLEAN-LEN:1)
        END-IF
    END-PERFORM.

VALIDATE-COUNTRY-RULES.
    PERFORM INITIALIZE-COUNTRY-TABLE
    MOVE "N" TO WS-COUNTRY-FOUND
    MOVE 0 TO WS-EXPECTED-LEN

    PERFORM VARYING WS-COUNTRY-INDEX FROM 1 BY 1 UNTIL WS-COUNTRY-INDEX > 9
        IF WS-COUNTRY-CODE = WS-COUNTRY-CODE-REF(WS-COUNTRY-INDEX)
            MOVE "Y" TO WS-COUNTRY-FOUND
            MOVE WS-COUNTRY-LEN-REF(WS-COUNTRY-INDEX) TO WS-EXPECTED-LEN
            EXIT PERFORM
        END-IF
    END-PERFORM

    IF WS-COUNTRY-FOUND NOT = "Y"
        MOVE "Unsupported IBAN country" TO LK-ERROR-MSG
        EXIT PARAGRAPH
    END-IF

    IF WS-CLEAN-LEN NOT = WS-EXPECTED-LEN
        MOVE "IBAN length does not match country" TO LK-ERROR-MSG
        EXIT PARAGRAPH
    END-IF

    IF WS-COUNTRY-CODE = "DE" OR
       WS-COUNTRY-CODE = "ES" OR
       WS-COUNTRY-CODE = "NO" OR
       WS-COUNTRY-CODE = "FI"
        PERFORM VARYING WS-INDEX FROM 5 BY 1 UNTIL WS-INDEX > WS-CLEAN-LEN
            IF WS-CLEAN-IBAN(WS-INDEX:1) IS NOT NUMERIC
                MOVE "Country BBAN must be numeric" TO LK-ERROR-MSG
                EXIT PARAGRAPH
            END-IF
        END-PERFORM
    END-IF.

BUILD-REARRANGED-IBAN.
    MOVE SPACES TO WS-REARRANGED-IBAN
    COMPUTE WS-HEAD-LEN = WS-CLEAN-LEN - 4
    COMPUTE WS-TAIL-START = WS-HEAD-LEN + 1
    IF WS-HEAD-LEN > 0
        MOVE WS-CLEAN-IBAN(5:WS-HEAD-LEN) TO WS-REARRANGED-IBAN(1:WS-HEAD-LEN)
    END-IF
    MOVE WS-CLEAN-IBAN(1:4) TO WS-REARRANGED-IBAN(WS-TAIL-START:4).

CALCULATE-MOD97.
    MOVE 0 TO WS-REMAINDER
    COMPUTE WS-ORD-A = FUNCTION ORD("A")

    PERFORM VARYING WS-INDEX FROM 1 BY 1 UNTIL WS-INDEX > WS-CLEAN-LEN
        MOVE WS-REARRANGED-IBAN(WS-INDEX:1) TO WS-CURRENT-CHAR
        IF WS-CURRENT-CHAR IS NUMERIC
            COMPUTE WS-DIGIT = FUNCTION NUMVAL(WS-CURRENT-CHAR)
            COMPUTE WS-REMAINDER = FUNCTION MOD((WS-REMAINDER * 10) + WS-DIGIT, 97)
        ELSE
            COMPUTE WS-ORD-CURRENT = FUNCTION ORD(WS-CURRENT-CHAR)
            COMPUTE WS-LETTER-VALUE = (WS-ORD-CURRENT - WS-ORD-A) + 10
            COMPUTE WS-TENS = WS-LETTER-VALUE / 10
            COMPUTE WS-ONES = FUNCTION MOD(WS-LETTER-VALUE, 10)
            COMPUTE WS-REMAINDER = FUNCTION MOD((WS-REMAINDER * 10) + WS-TENS, 97)
            COMPUTE WS-REMAINDER = FUNCTION MOD((WS-REMAINDER * 10) + WS-ONES, 97)
        END-IF
    END-PERFORM.
